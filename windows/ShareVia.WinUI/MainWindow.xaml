<Window
    x:Class="ShareVia.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="ShareVia V2"
    Width="1280"
    Height="860">

    <Grid Background="#F7FBFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="16" Background="#FFFFFFFF" BorderBrush="#220B6A61" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="#FF0B6A61"
                    Text="ShareVia" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="#FF385E5A"
                    Text="WinUI 3 migration scaffold for full parity native shell" />
            </StackPanel>
        </Border>

        <NavigationView
            x:Name="RootNav"
            Grid.Row="1"
            PaneDisplayMode="Left"
            IsSettingsVisible="False"
            SelectionChanged="RootNav_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="home" />
                <NavigationViewItem Content="Devices" Tag="devices" />
                <NavigationViewItem Content="Profile" Tag="profile" />
                <NavigationViewItem Content="History" Tag="history" />
                <NavigationViewItem Content="Settings" Tag="settings" />
                <NavigationViewItem Content="Ecosystem" Tag="ecosystem" />
                <NavigationViewItem Content="Diagnostics" Tag="diagnostics" />
                <NavigationViewItem Content="Tools" Tag="tools" />
            </NavigationView.MenuItems>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    x:Name="SectionTitle"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="#FF0F1D1B"
                    Text="Home" />

                <Border
                    x:Name="ModeCard"
                    Grid.Row="1"
                    Margin="0,14,0,0"
                    Padding="14"
                    Background="#EEF7F5"
                    CornerRadius="14">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Quick Connect" />
                        <TextBlock Foreground="#FF385E5A" Text="Offline and Online modes are unified here. Advanced tools stay in sidebar." />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="Offline Mode" />
                            <Button Content="Online Mode" />
                            <Button Content="Connect Hub" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Margin="0,16,0,0"
                    Padding="14"
                    Background="#FFFFFFFF"
                    BorderBrush="#220B6A61"
                    BorderThickness="1"
                    CornerRadius="14">
                    <StackPanel Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="Migration Notes" />
                        <TextBlock Foreground="#FF385E5A" Text="This WinUI shell is the V2 migration target. Transport service adapters are defined in Services/TransportStateCoordinator.cs." />
                        <TextBlock Foreground="#FF385E5A" Text="Keep LAN offline service parity and add native WebRTC with relay fallback in phase 2." />
                    </StackPanel>
                </Border>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
