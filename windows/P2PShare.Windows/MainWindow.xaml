<Window x:Class="ShareVia.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ShareVia Native"
        Height="820"
        Width="1220"
        MinHeight="680"
        MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F6F8FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E7EAF0" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">
                <Button x:Name="HamburgerButton"
                        DockPanel.Dock="Left"
                        Click="HamburgerButton_Click"
                        Width="48"
                        Height="40"
                        Margin="10,8,6,8"
                        FontSize="12"
                        Content="Menu" />
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#222831"
                           Text="ShareVia Native" />
                <TextBlock x:Name="TopStatusText"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Margin="0,0,16,0"
                           Foreground="#5E6470"
                           Text="Offline mode ready." />
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="MenuColumn" Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#0F172A">
                <StackPanel Margin="10,14">
                    <TextBlock Text="Navigation"
                               Foreground="#A8B0C2"
                               FontSize="12"
                               Margin="8,4,0,10" />
                    <Button x:Name="HomeMenuButton"
                            Click="HomeMenuButton_Click"
                            Margin="0,4,0,0"
                            Height="40"
                            Content="Home" />
                    <Button x:Name="ProfileMenuButton"
                            Click="ProfileMenuButton_Click"
                            Margin="0,8,0,0"
                            Height="40"
                            Content="Profile" />
                    <Button x:Name="HistoryMenuButton"
                            Click="HistoryMenuButton_Click"
                            Margin="0,8,0,0"
                            Height="40"
                            Content="History" />
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="16">
                <Grid x:Name="HomePanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="White"
                            BorderBrush="#E4E8EF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Offline-first nearby session"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="#5E6470"
                                       Text="Discovery and transfer are native (LAN + direct socket). Internet is optional." />
                            <WrapPanel Margin="0,12,0,0">
                                <Button x:Name="StartNearbyButton"
                                        Click="StartNearbyButton_Click"
                                        Width="120"
                                        Height="34"
                                        Content="Start Nearby" />
                                <Button x:Name="StopNearbyButton"
                                        Click="StopNearbyButton_Click"
                                        Width="90"
                                        Height="34"
                                        Margin="10,0,0,0"
                                        Content="Stop" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1"
                               Margin="2,14,0,8"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Text="Nearby devices" />

                    <Border Grid.Row="2"
                            Background="White"
                            BorderBrush="#E4E8EF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                        <ListView x:Name="PeersListView" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEF1F6" BorderThickness="0,0,0,1" Padding="0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                                <TextBlock Margin="0,2,0,0" Foreground="#5E6470" FontSize="12" Text="{Binding AddressLabel}" />
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1">
                                                <Button Content="Pair"
                                                        Width="66"
                                                        Height="30"
                                                        Tag="{Binding Id}"
                                                        Click="PairPeerButton_Click" />
                                                <Button Content="Send File"
                                                        Width="78"
                                                        Height="30"
                                                        Margin="8,0,0,0"
                                                        Tag="{Binding Id}"
                                                        Click="SendFileButton_Click" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>

                    <TextBlock Grid.Row="3"
                               Margin="2,14,0,8"
                               FontWeight="SemiBold"
                               FontSize="15"
                               Text="Live transfers" />

                    <Border Grid.Row="4"
                            Background="White"
                            BorderBrush="#E4E8EF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                        <ListView x:Name="TransfersListView" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEF1F6" BorderThickness="0,0,0,1" Padding="0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,2,0,0" Foreground="#5E6470" FontSize="12" Text="{Binding Subtitle}" />
                                            <ProgressBar Margin="0,6,0,0" Height="6" Minimum="0" Maximum="1" Value="{Binding Progress}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>

                <Grid x:Name="ProfilePanel" Visibility="Collapsed">
                    <Border Background="White"
                            BorderBrush="#E4E8EF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Profile"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                            <TextBlock Margin="0,6,0,12"
                                       Foreground="#5E6470"
                                       Text="Choose your name and display picture for easier pairing." />
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="72"
                                        Height="72"
                                        CornerRadius="36"
                                        BorderBrush="#D1D7E2"
                                        BorderThickness="1"
                                        ClipToBounds="True">
                                    <Image x:Name="AvatarImage" Stretch="UniformToFill" />
                                </Border>
                                <Button x:Name="ChangeAvatarButton"
                                        Click="ChangeAvatarButton_Click"
                                        Margin="14,0,0,0"
                                        Width="120"
                                        Height="34"
                                        Content="Change DP" />
                            </StackPanel>
                            <TextBlock Margin="0,16,0,6" Text="Display name" />
                            <TextBox x:Name="ProfileNameTextBox" Height="34" />
                            <Button x:Name="SaveProfileButton"
                                    Click="SaveProfileButton_Click"
                                    Margin="0,14,0,0"
                                    Width="120"
                                    Height="34"
                                    Content="Save Profile" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid x:Name="HistoryPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="Activity history" />
                        <Button x:Name="ClearHistoryButton"
                                DockPanel.Dock="Right"
                                Click="ClearHistoryButton_Click"
                                Width="90"
                                Height="30"
                                Content="Clear" />
                    </DockPanel>

                    <Border Grid.Row="1"
                            Background="White"
                            BorderBrush="#E4E8EF"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                        <ListView x:Name="HistoryListView" BorderThickness="0">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEF1F6" BorderThickness="0,0,0,1" Padding="0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
                                            <TextBlock Margin="0,2,0,0" Foreground="#5E6470" FontSize="12" Text="{Binding Subtitle}" />
                                            <TextBlock Margin="0,2,0,0" Foreground="#5E6470" FontSize="11" Text="{Binding TimeLabel}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
