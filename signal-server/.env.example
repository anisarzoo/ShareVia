PORT=9000
HOST=0.0.0.0
PEER_PATH=/peerjs
REALTIME_PATH=/v2/realtime
TRUST_PROXY=false
REQUEST_BODY_LIMIT=1mb

# Use "*" for public allow, or comma-separated origins for production lock-down.
CORS_ORIGIN=*
RATE_LIMIT=240
RATE_LIMIT_WINDOW_MS=60000
ALLOW_DISCOVERY=false

# Auth and device-link behavior
MAGIC_LINK_TTL_MS=900000
DEVICE_LINK_TTL_MS=300000
# Set true only in local development if you need token echo in API response
AUTH_DEV_ECHO_TOKEN=false

# ICE server config for native WebRTC clients
ICE_STUN_URLS=stun:stun.l.google.com:19302
ICE_TURN_URLS=
ICE_TURN_USERNAME=
ICE_TURN_CREDENTIAL=
ICE_TTL_SEC=3600

# Telemetry memory retention
TELEMETRY_RETENTION=2000

# Optional direct TLS. In production, TLS termination via reverse proxy is preferred.
ENABLE_HTTPS=false
TLS_KEY_FILE=
TLS_CERT_FILE=
TLS_CA_FILE=

